# .gitignore
# ============================================================================

# Training Data (NEVER COMMIT)
data/
!data/examples/
data/**/*
!data/**/.gitkeep

# Raw scraped content
*.jsonl
*.json
!configs/**/*.json
!data/examples/*.json

# Text files 
*.txt
!requirements*.txt
!LICENSE

# ============================================================================
# MODEL WEIGHTS 
# ============================================================================

# Model files
models/
!models/.gitkeep
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.h5
*.onnx
*.pb

# Adapter weights
adapter_config.json
adapter_model.bin

# ============================================================================
# GENERATED OUTPUTS 
# ============================================================================

# All outputs
outputs/
!outputs/.gitkeep

# Generation results
generations/
generated_*.txt

# ============================================================================
# CACHE & TEMPORARY FILES
# ============================================================================

# Scraper cache 
cache/
.cache/
*.cache

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================================================
# LOGS & MONITORING
# ============================================================================

# Log files 
*.log
logs/
*.out
*.err

# Training logs
runs/
wandb/
tensorboard/
mlruns/

# ============================================================================
# PYTHON ENVIRONMENT
# ============================================================================

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# Environment variables
.env
.env.*
!.env.example

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ============================================================================
# BUILD ARTIFACTS
# ============================================================================

# Python packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# ============================================================================
# DOCUMENTATION BUILD
# ============================================================================

docs/_build/
docs/.doctrees/
site/

# ============================================================================
# SYSTEM FILES
# ============================================================================

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================================================
# PACKAGE DISTRIBUTION
# ============================================================================

*.whl
*.tar.gz
*.zip

# ============================================================================
# BACKUP FILES
# ============================================================================

*.bak
*.backup
*.old
*.orig
*.swp
*.tmp

# ============================================================================
# DATASET METADATA 
# ============================================================================

# URL lists with scraped sources
urls.txt
urls_*.txt
scraped_urls.txt
author_list.txt

# Metadata that might reveal sources
dataset_metadata.json
scraper_log.json

# ============================================================================
# EXCEPTION: ALLOW THESE SPECIFIC FILES
# ============================================================================

# Keep directory structure
!**/.gitkeep

# Keep example configs (non-sensitive)
!configs/**/*.yaml
!configs/**/*.yml

# Keep example data (sanitized only)
!data/examples/sample_scenes.jsonl
!data/examples/example_metadata.json

# Keep documentation
!docs/**/*.md
!*.md

# Keep requirements
!requirements.txt
!requirements-dev.txt

# Keep license
!LICENSE

# Keep setup files
!setup.py
!pyproject.toml
!MANIFEST.in

# Keep source code
!src/**/*.py

# Keep tests
!tests/**/*.py

# Keep scripts
!scripts/**/*.py

# Keep configs
!configs/**/*.yaml
!configs/**/*.yml

# Keep GitHub workflows
!.github/**/*.yml
!.github/**/*.md
